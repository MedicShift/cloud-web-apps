# Database Setup
DB_HOST=postgres
DB_PORT=5432
DB_USER=medicshift_user
DB_PASSWORD=medicshift_password
DB_NAME=medicshift_db

# JWT Auth
JWT_SECRET=super_secret_jwt_key_change_me_in_prod
JWT_EXPIRATION=15m

# Refresh Tokens
REFRESH_TOKEN_SECRET=refresh_secret_change_me_in_prod
REFRESH_TOKEN_EXPIRATION=7d

# Security
PASSWORD_PEPPER=pepper_secret_change_me_in_prod
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=15

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# App Config
PORT=3000
NODE_ENV=development

# Neon / Remote Database
# If DATABASE_URL is set, it will override the individual DB_* variables above
DATABASE_URL=postgres://user:password@hostname:5432/dbname?sslmode=require
